# Reservation email delivery (optional).
# Without these, the reservation form still works and logs requests server-side.
# To actually deliver requests by email, sign up at https://resend.com,
# verify your sending domain, then set:

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESERVATIONS_EMAIL=reservations@kayumanggi.ph
RESERVATIONS_FROM=Kayumanggi <reserve@kayumanggi.ph>
