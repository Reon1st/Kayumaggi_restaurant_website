# Reservation capture (optional).
# Without these, the reservation form still works and logs requests server-side.
#
# To capture reservations as rows in Airtable:
#   1. Create a base with a table named "Reservations"
#   2. Give it these columns — the names must match EXACTLY, or the API 422s:
#
#        Name       Single line text
#        Email      Email
#        Phone      Single line text
#        Date       Date              (ISO / yyyy-mm-dd)
#        Time       Single line text
#        Guests     Single line text  (or Single select)
#        Occasion   Single line text  (or Single select)
#        Notes      Long text
#        Status     Single select     (include an option: "New")
#        Submitted  Date              (include time)
#
#   3. Mint a Personal Access Token at https://airtable.com/create/tokens
#      Scope it to `data.records:write` on THIS BASE ONLY — not your whole
#      account. A leaked token should cost you one base, not everything.
#   4. Grab the base id ("app...") from https://airtable.com/api

#   NOTE: Status needs three options — "Confirmed", "Declined", and "New".
#   (typecast will create them on first write, but pre-making them is tidier.)

AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx
AIRTABLE_TABLE=Reservations


# ---------------------------------------------------------------------------
# Guest email (Brevo). Optional — without it the form still decides and captures,
# it just doesn't mail anyone.
#
# Brevo rather than Resend/Mailgun/SES because those require a verified DOMAIN to
# email arbitrary people. Brevo lets you verify a single SENDER ADDRESS — so you
# can mail real guests from an address you already own, with no domain at all.
#
#   1. Sign up at https://www.brevo.com (free: 300 emails/day, no card)
#   2. Senders, Domains & IPs → Senders → add and VERIFY your address
#      (they mail you a confirmation link — click it, or nothing will send)
#   3. SMTP & API → API Keys → generate a key
#
# RESERVATIONS_FROM_EMAIL must be the address you verified in step 2.
# RESERVATIONS_FROM_NAME is the display name the inbox actually shows — the guest
# sees "Kayumanggi Reservations", not your address, unless they expand the header.
# ---------------------------------------------------------------------------

BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
RESERVATIONS_FROM_EMAIL=you@youraddress.com
RESERVATIONS_FROM_NAME=Kayumanggi Reservations


# Covers the room seats in one seating. The site says "forty seats".
# Set it to 4 to demo a decline without submitting the form twenty times.
RESERVATION_CAPACITY=40
